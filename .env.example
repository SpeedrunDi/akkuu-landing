# Copy to .env.local (used only at build time, not shipped to client)

# hCaptcha site key is public and is inlined into the client bundle.
# Only fill if you want the hCaptcha widget to work. Leave empty to disable.
PUBLIC_HCAPTCHA_SITE_KEY=

# Override the contact endpoint (defaults to /api/contact.php on same host)
PUBLIC_CONTACT_ENDPOINT=/api/contact.php
