---
import SectionHeader from '../components/SectionHeader.astro';
import ProductsCarousel from '../islands/ProductsCarousel';
---

<section id="products" class="relative overflow-hidden bg-cream-50 py-24 lg:py-32">
  <!-- Decorative background -->
  <div class="absolute inset-0 -z-10 pointer-events-none">
    <svg class="absolute -right-32 -top-32 w-[60%] max-w-[720px] text-brand-700/5" viewBox="0 0 200 200" fill="currentColor" aria-hidden="true">
      <ellipse cx="100" cy="90" rx="70" ry="95"/>
    </svg>
    <svg class="absolute -left-24 bottom-0 w-[40%] max-w-[480px] text-gold-400/10" viewBox="0 0 200 200" fill="currentColor" aria-hidden="true">
      <ellipse cx="100" cy="110" rx="65" ry="90"/>
    </svg>
  </div>

  <div class="container-edge">
    <div class="reveal-group mb-16 flex flex-col items-start gap-6 md:flex-row md:items-end md:justify-between">
      <SectionHeader
        eyebrow="Коллекция"
        title="Яйца премиум-класса <span class='underline-accent'>для каждой кухни</span>"
        description="От стабильных столовых до обогащённых — четыре линейки продукции, упакованных в соответствии с техническим регламентом Таможенного союза."
      />
      <div class="hidden md:flex items-center gap-3 text-xs uppercase tracking-[0.18em] text-ink-500 fade-up">
        <span class="h-px w-12 bg-ink-900/20"></span>
        Используйте ← → для навигации
      </div>
    </div>

    <div class="fade-up">
      <ProductsCarousel client:visible />
    </div>
  </div>
</section>
