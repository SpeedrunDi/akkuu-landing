---
import SectionHeader from '../components/SectionHeader.astro';
import QualityIcon from '../components/QualityIcon.astro';
import { QUALITY_STANDARDS } from '../data/content';
---

<section id="quality" class="relative bg-ink-900 text-cream-50 py-24 lg:py-32 overflow-hidden">
  <div class="noise-overlay opacity-[0.06]"></div>

  <!-- Subtle gold radial -->
  <div
    class="absolute inset-0 -z-0 pointer-events-none"
    style="background: radial-gradient(900px 500px at 85% 15%, color-mix(in srgb, var(--color-gold-500) 22%, transparent), transparent 60%);"
  ></div>

  <div class="container-edge relative">
    <div class="reveal-group max-w-3xl">
      <span class="eyebrow fade-up !text-gold-400">
        Стандарты качества
      </span>
      <h2 class="text-display font-display mt-5 text-cream-50 fade-up">
        Каждое яйцо — результат<br/>
        <span class="text-gold-400">безупречного контроля</span>
      </h2>
      <p class="mt-6 text-lg leading-relaxed text-cream-200 fade-up">
        Полный цикл производства — от корма до прилавка — проходит многоуровневый контроль качества.
        Мы работаем по международным стандартам, которые гарантируют безопасность и свежесть продукции.
      </p>
    </div>

    <div class="reveal-group mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {QUALITY_STANDARDS.map((s, i) => (
        <div class="group relative stagger-child rounded-3xl border border-cream-50/10 bg-cream-50/[0.03] p-8 transition-all duration-700 ease-[cubic-bezier(0.16,1,0.3,1)] hover:-translate-y-1 hover:border-gold-500/50 hover:bg-cream-50/[0.06]">
          <div class="text-xs font-mono uppercase tracking-[0.2em] text-cream-50/40">{String(i + 1).padStart(2, '0')}</div>
          <div class="mt-6 inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-gold-500/10 text-gold-400 ring-1 ring-gold-500/20 transition-all duration-500 group-hover:bg-gold-500/20 group-hover:ring-gold-500/50">
            <QualityIcon name={s.icon as any} />
          </div>
          <h3 class="mt-6 font-display text-2xl text-cream-50">{s.title}</h3>
          <p class="mt-3 text-sm leading-relaxed text-cream-200/80">{s.description}</p>

          <!-- Gold underline on hover -->
          <div class="absolute bottom-0 left-8 right-8 h-px origin-left scale-x-0 bg-gradient-to-r from-gold-500 via-gold-400 to-transparent transition-transform duration-700 group-hover:scale-x-100"></div>
        </div>
      ))}
    </div>

    <!-- Bottom trust line -->
    <div class="mt-16 flex flex-wrap items-center justify-center gap-x-12 gap-y-6 border-t border-cream-50/10 pt-10 fade-up">
      <span class="text-xs uppercase tracking-[0.2em] text-cream-50/50">Сертификаты и соответствия</span>
      {['ISO 22000', 'HACCP', 'ТР ТС 021/2011', 'ТР ТС 022/2011'].map((label) => (
        <span class="font-display text-lg text-cream-50/80">{label}</span>
      ))}
    </div>
  </div>
</section>
